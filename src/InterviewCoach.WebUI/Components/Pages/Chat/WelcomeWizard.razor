@inject IJSRuntime JS

@if (isVisible)
{
    <div class="wizard-backdrop" @onclick="HandleBackdropClick">
        <div class="wizard-modal" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-labelledby="wizard-title">
            <div class="wizard-header">
                <div class="wizard-step-indicator">
                    @for (int i = 0; i < steps.Length; i++)
                    {
                        var stepIndex = i;
                        <button class="wizard-step-dot @(stepIndex == currentStep ? "active" : stepIndex < currentStep ? "completed" : "")"
                                @onclick="() => GoToStep(stepIndex)"
                                title="@steps[stepIndex].Title"
                                aria-label="Paso @(stepIndex + 1): @steps[stepIndex].Title">
                        </button>
                    }
                </div>
                <button class="wizard-close-btn" @onclick="CloseWizard" title="Cerrar" aria-label="Cerrar asistente">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <div class="wizard-body">
                <div class="wizard-step-icon" aria-hidden="true">@((MarkupString)steps[currentStep].Icon)</div>
                <h2 class="wizard-title" id="wizard-title">@steps[currentStep].Title</h2>
                <p class="wizard-description">@steps[currentStep].Description</p>
                @if (steps[currentStep].Tips != null)
                {
                    <ul class="wizard-tips">
                        @foreach (var tip in steps[currentStep].Tips!)
                        {
                            <li>@tip</li>
                        }
                    </ul>
                }
            </div>

            <div class="wizard-footer">
                <div class="wizard-progress-text">Paso @(currentStep + 1) de @steps.Length</div>
                <div class="wizard-nav-buttons">
                    @if (currentStep > 0)
                    {
                        <button class="btn-default wizard-btn-prev" @onclick="PreviousStep">
                            Anterior
                        </button>
                    }
                    @if (currentStep < steps.Length - 1)
                    {
                        <button class="btn-default wizard-btn-skip" @onclick="CloseWizard">
                            Omitir
                        </button>
                        <button class="wizard-btn-next" @onclick="NextStep">
                            Siguiente
                        </button>
                    }
                    else
                    {
                        <button class="wizard-btn-next" @onclick="CloseWizard">
                            ¡Empezar!
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private const string LocalStorageKey = "interviewcoach_wizard_seen";

    private bool isVisible = false;
    private int currentStep = 0;

    private record WizardStep(string Icon, string Title, string Description, string[]? Tips = null);

    private readonly WizardStep[] steps =
    [
        new(
            Icon: """<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>""",
            Title: "¡Bienvenido a Interview Coach!",
            Description: "Tu entrenador personal de entrevistas impulsado por IA. Te ayudaré a prepararte para cualquier tipo de entrevista de trabajo, desde preguntas conductuales hasta técnicas.",
            Tips: ["Preparación para entrevistas conductuales", "Revisión de currículum con IA", "Práctica de preguntas técnicas", "Consejos personalizados según el puesto"]
        ),
        new(
            Icon: """<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m18.375 12.739-7.693 7.693a4.5 4.5 0 0 1-6.364-6.364l10.94-10.94A3 3 0 1 1 19.5 7.372L8.552 18.32m.009-.01-.01.01m5.699-9.941-7.81 7.81a1.5 1.5 0 0 0 2.112 2.13" /></svg>""",
            Title: "Adjunta tu currículum",
            Description: "Para obtener consejos personalizados, adjunta tu currículum y la descripción del puesto al que aspiras. Haz clic en el icono de clip en el área de mensaje.",
            Tips: ["Formatos admitidos: PDF, DOCX, DOC, TXT, MD, HTML", "Tamaño máximo: 10 MB por archivo", "Puedes adjuntar tu currículum o la oferta de trabajo", "Cuanta más información compartas, mejores consejos recibirás"]
        ),
        new(
            Icon: """<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" /></svg>""",
            Title: "Inicia la conversación",
            Description: "Escribe tu pregunta o elige una de las sugerencias rápidas para comenzar. Interview Coach responderá con consejos detallados y personalizados.",
            Tips: ["Usa las tarjetas de sugerencia para empezar rápidamente", "Puedes hacer preguntas específicas sobre cualquier aspecto", "El asistente recuerda el contexto de la conversación", "Escribe 'nueva conversación' o usa el botón para reiniciar"]
        ),
        new(
            Icon: """<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.601c-.38-.325-.178-.948.321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" /></svg>""",
            Title: "Consejos para el éxito",
            Description: "Saca el máximo provecho de Interview Coach con estos consejos clave.",
            Tips: ["Sé específico sobre el puesto y la empresa", "Pide ejemplos de respuestas con el método STAR", "Solicita feedback sobre tus respuestas", "Practica regularmente antes de la entrevista real"]
        )
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var seen = await JS.InvokeAsync<string?>("localStorage.getItem", LocalStorageKey);
                if (seen != "true")
                {
                    isVisible = true;
                    StateHasChanged();
                }
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }

    private void NextStep()
    {
        if (currentStep < steps.Length - 1)
            currentStep++;
    }

    private void PreviousStep()
    {
        if (currentStep > 0)
            currentStep--;
    }

    private void GoToStep(int step)
    {
        currentStep = step;
    }

    private void HandleBackdropClick()
    {
        CloseWizard();
    }

    private async void CloseWizard()
    {
        isVisible = false;
        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", LocalStorageKey, "true");
        }
        catch (JSDisconnectedException)
        {
        }
    }
}
