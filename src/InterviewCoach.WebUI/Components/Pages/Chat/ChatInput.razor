@using InterviewCoach.WebUI.Services
@inject IJSRuntime JS

<div class="input-outer">
    <EditForm Model="@this" OnValidSubmit="@SendMessageAsync" class="page-width">
        <label class="input-box">
            @if (attachedFile is not null)
            {
                <div class="file-chip">
                    📄 @attachedFile.Name
                    <button type="button" @onclick="RemoveAttachment" title="Remove attachment" aria-label="Remove attachment">✕</button>
                </div>
            }

            <textarea @ref="@textArea" @bind="@messageText" placeholder="Message Interview Coach…" rows="1" aria-label="Message to Interview Coach"></textarea>

            <div class="tools">
                <button type="button" class="attach" title="Attach file" aria-label="Attach file" @onclick="TriggerFileInput">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="tool-icon" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m18.375 12.739-7.693 7.693a4.5 4.5 0 0 1-6.364-6.364l10.94-10.94A3 3 0 1 1 19.5 7.372L8.552 18.32m.009-.01-.01.01m5.699-9.941-7.81 7.81a1.5 1.5 0 0 0 2.112 2.13" />
                    </svg>
                </button>
                <InputFile @ref="@fileInput" OnChange="@OnFileSelected" style="display:none"
                           accept=".pdf,.docx,.doc,.txt,.md,.html" />
                <button type="submit" title="Send message" aria-label="Send message" class="send-button">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="tool-icon" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5 12 3m0 0 7.5 7.5M12 3v18" />
                    </svg>
                </button>
            </div>
        </label>
        <p class="input-hint">Interview Coach may make mistakes. Always verify important information.</p>
    </EditForm>
</div>

@code {
    private ElementReference textArea;
    private string? messageText;
    private IBrowserFile? attachedFile;
    private InputFile? fileInput;

    [Parameter]
    public EventCallback<ChatMessage> OnSend { get; set; }

    [Parameter]
    public string? Suggestion { get; set; }

    [Parameter]
    public EventCallback OnSuggestionConsumed { get; set; }

    /// <summary>
    /// The currently attached file, if any. Read by Chat.razor to upload before sending.
    /// </summary>
    public IBrowserFile? AttachedFile => attachedFile;

    /// <summary>
    /// Clears the attached file after it has been processed.
    /// </summary>
    public void ClearAttachment() => attachedFile = null;

    public ValueTask FocusAsync()
        => textArea.FocusAsync();

    private async Task TriggerFileInput()
    {
        if (fileInput?.Element is not null)
        {
            await JS.InvokeVoidAsync("triggerClick", fileInput.Element);
        }
    }

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is not null && FileUploadService.IsAllowedFile(file.Name))
        {
            attachedFile = file;
        }
    }

    private void RemoveAttachment()
    {
        attachedFile = null;
    }

    private async Task SendMessageAsync()
    {
        if (messageText is { Length: > 0 } text || attachedFile is not null)
        {
            var finalText = messageText ?? "";
            messageText = null;
            await OnSend.InvokeAsync(new ChatMessage(ChatRole.User, finalText));
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Suggestion is { Length: > 0 } suggestion && messageText != suggestion)
        {
            messageText = suggestion;
            await OnSuggestionConsumed.InvokeAsync();
            await textArea.FocusAsync();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Chat/ChatInput.razor.js");
                await module.InvokeVoidAsync("init", textArea);
                await module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }
}
